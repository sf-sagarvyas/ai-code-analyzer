# Copy this file to .env.local and fill in your Anthropic API key.
# Get a key at https://console.anthropic.com/

ANTHROPIC_API_KEY=sk-ant-...

# Model to use for the semantic review pass.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Path to the PMD CLI directory (populated by npm run setup:pmd).
PMD_HOME=./bin/pmd